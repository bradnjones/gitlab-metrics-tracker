# GitLab Configuration
# GITLAB_TOKEN and GITLAB_PROJECT_PATH are intentionally absent.
# Credentials are entered at runtime via the Settings modal in the UI
# and held in browser memory only — never stored on disk or in env vars.
GITLAB_URL=https://gitlab.com

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS — comma-free single origin allowed to call the API from a browser.
# Leave unset (default) for same-origin only (recommended for local/homelab).
# Example: ALLOWED_ORIGIN=https://dashboard.example.com
# ALLOWED_ORIGIN=

# Basic Auth — protects all /api routes when both vars are set. /health stays open.
# Leave both unset (default) to disable auth (e.g. pure local dev with no exposure).
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASS=changeme

# Data Storage
DATA_DIR=./src/data

# Cache Configuration (Story V9.2)
# Cache TTL (Time-To-Live) in hours - how long cached iteration data remains valid
# Set to 0 to disable cache expiration (cache lives forever until manually cleared)
# Default: 6 hours (good balance for daily development workflows)
CACHE_TTL_HOURS=6

# AI Metric Review (optional — feature is disabled when AI_REVIEW_ENABLED is absent)
# WARNING: Enabling this feature sends sprint metadata (iteration titles, metric values,
# annotation text) to the Anthropic API. Do not enable on confidential projects without
# confirming that external data egress is acceptable.
# ANTHROPIC_MODEL=claude-sonnet-4-6     # optional, defaults to claude-sonnet-4-6
# AI_REVIEW_ENABLED=true                # server-side opt-in gate; API key is configured in Settings UI

