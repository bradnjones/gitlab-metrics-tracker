# GitLab Configuration
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_personal_access_token
GITLAB_PROJECT_PATH=group/project

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS — comma-free single origin allowed to call the API from a browser.
# Leave unset (default) for same-origin only (recommended for local/homelab).
# Example: ALLOWED_ORIGIN=https://dashboard.example.com
# ALLOWED_ORIGIN=

# Basic Auth — protects all /api routes when both vars are set. /health stays open.
# Leave both unset (default) to disable auth (e.g. pure local dev with no exposure).
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASS=changeme

# Data Storage
DATA_DIR=./src/data

# Cache Configuration (Story V9.2)
# Cache TTL (Time-To-Live) in hours - how long cached iteration data remains valid
# Set to 0 to disable cache expiration (cache lives forever until manually cleared)
# Default: 6 hours (good balance for daily development workflows)
CACHE_TTL_HOURS=6
